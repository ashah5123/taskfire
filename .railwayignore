# ── .railwayignore ─────────────────────────────────────────────────────────────
# Files and directories excluded from the Railway build context.
# Follows the same syntax as .dockerignore.

# Dependencies — reinstalled during the Docker build
node_modules/
**/node_modules/

# Build output — rebuilt from source in Docker
dist/
build/
**/dist/
**/build/

# Go build artifacts
worker/taskfire-worker
worker/*.exe
**/*.test

# Test files — not needed in production images
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.test.go
**/testdata/
**/__mocks__/
**/test-setup.ts
**/vitest.config.ts
**/jest.config.js

# Coverage reports
coverage/
*.lcov
**/.nyc_output/

# Local environment files — secrets must be set in Railway dashboard
.env
.env.*
!.env.example

# Editor and OS artifacts
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Docker Compose files (not needed by Railway)
docker-compose.yml
docker-compose.*.yml

# Local development tooling
Makefile
nginx/
prometheus/

# Git
.git/
.github/

# Logs
*.log
npm-debug.log*
