# ── Taskfire environment variables ────────────────────────────────────────────
#
# Copy this file to .env and fill in values for local development.
#
#   cp .env.example .env
#
# ── Railway deployment ─────────────────────────────────────────────────────────
# When deploying on Railway, do NOT set these manually — use Railway's variable
# reference syntax in the dashboard so services stay in sync automatically:
#
#   REDIS_URL    = ${{Redis.REDIS_URL}}       (from Railway Redis plugin)
#   DATABASE_URL = ${{Postgres.DATABASE_URL}} (from Railway PostgreSQL plugin)
#
# All other variables are set under each service → Variables in the dashboard.
# ──────────────────────────────────────────────────────────────────────────────

# ── Redis ──────────────────────────────────────────────────────────────────────

# Connection URL for the Redis broker.
# Local Docker Compose:  redis://redis:6379          (service name = "redis")
# Local host:            redis://localhost:6379
# Railway:               ${{Redis.REDIS_URL}}         (injected automatically)
REDIS_URL=redis://localhost:6379

# ── PostgreSQL ─────────────────────────────────────────────────────────────────

# Connection URL for the Postgres persistence layer.
# Local Docker Compose:  postgresql://taskfire:taskfire@postgres:5432/taskfire
# Local host:            postgresql://taskfire:taskfire@localhost:5432/taskfire
# Railway:               ${{Postgres.DATABASE_URL}}   (injected automatically)
DATABASE_URL=postgresql://taskfire:taskfire@localhost:5432/taskfire

# Individual Postgres credentials — used by docker-compose to initialise the
# cluster.  Not needed on Railway (the managed plugin handles this).
POSTGRES_USER=taskfire
POSTGRES_PASSWORD=taskfire
POSTGRES_DB=taskfire

# ── API server ─────────────────────────────────────────────────────────────────

# Port the Fastify HTTP server binds to inside the container.
# Railway overrides this automatically with its own $PORT — leave blank on Railway.
API_PORT=3000

# Comma-separated list of allowed CORS origins.
# Local:   http://localhost
# Railway: https://<your-dashboard-service>.up.railway.app
# Use '*' only in local development — always restrict in production.
CORS_ORIGIN=http://localhost

# Node.js environment: development | production | test
NODE_ENV=production

# ── Authentication ─────────────────────────────────────────────────────────────

# Secret used to sign JWT tokens.  Must be at least 32 characters.
# Generate a strong value with:  openssl rand -hex 32
JWT_SECRET=replace-this-with-a-strong-random-secret-at-least-32-chars

# ── Go Worker ──────────────────────────────────────────────────────────────────

# Minimum and maximum goroutines in the worker pool.
# Railway Starter (shared vCPU): WORKER_MIN=2  WORKER_MAX=8
# Railway Pro (dedicated vCPU):  WORKER_MIN=4  WORKER_MAX=32
WORKER_MIN=4
WORKER_MAX=32

# Port the Prometheus /metrics endpoint is exposed on inside the container.
METRICS_PORT=9090

# Structured log level: debug | info | warn | error
LOG_LEVEL=info

# ── Dashboard (Vite build-time variables) ──────────────────────────────────────
#
# These are baked into the static bundle at build time by Vite.
# They must be set as Build Variables (not runtime env vars) in Railway.
#
# Local (behind nginx):  leave empty — dashboard hits /api/* via relative paths
# Local (direct Vite):   http://localhost:3000
# Railway:               https://<your-api-service>.up.railway.app
VITE_API_URL=

# WebSocket URL for the live-metrics connection.
# Local (behind nginx):  leave empty — auto-detected from window.location
# Local (direct Vite):   ws://localhost:3000
# Railway:               wss://<your-api-service>.up.railway.app
VITE_WS_URL=
