# ── Redis ─────────────────────────────────────────────────────────────────────

# Connection URL for the Redis broker.
# Format: redis[s]://[[username][:password]@][host][:port][/db-number]
REDIS_URL=redis://localhost:6379

# ── PostgreSQL ────────────────────────────────────────────────────────────────

# Connection URL for the Postgres persistence layer.
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://taskfire:taskfire@localhost:5432/taskfire

# Individual Postgres credentials (used by docker-compose to init the cluster).
POSTGRES_USER=taskfire
POSTGRES_PASSWORD=taskfire
POSTGRES_DB=taskfire

# ── API server ────────────────────────────────────────────────────────────────

# Port the Fastify HTTP server binds to inside the container.
API_PORT=3000

# Comma-separated list of allowed CORS origins.
# Use '*' only in local development — always restrict in production.
CORS_ORIGIN=http://localhost

# Node.js environment: development | production | test
NODE_ENV=production

# ── Authentication ────────────────────────────────────────────────────────────

# Secret used to sign JWT tokens.  Must be at least 32 characters.
# Generate a strong value with: openssl rand -hex 32
JWT_SECRET=replace-this-with-a-strong-random-secret-at-least-32-chars

# ── Go Worker ─────────────────────────────────────────────────────────────────

# Number of concurrent job-processing goroutines in the worker pool.
WORKER_COUNT=10

# Port the Prometheus /metrics endpoint is exposed on inside the container.
METRICS_PORT=9090

# Structured log level: debug | info | warn | error
LOG_LEVEL=info

# ── Dashboard (Vite build-time variables) ─────────────────────────────────────

# Base URL of the API server — used by the React app to make HTTP requests.
# Leave empty to use relative paths (recommended when served behind nginx).
VITE_API_URL=

# WebSocket origin for the live-metrics connection.
# Leave empty to auto-detect from window.location (recommended behind nginx).
VITE_WS_URL=

# ── Local development overrides ────────────────────────────────────────────────
# Uncomment these when running services outside Docker (make worker-dev, etc.)

# VITE_API_URL=http://localhost:3000
# VITE_WS_URL=ws://localhost:3000
